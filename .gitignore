# ═══════════════════════════════════════════════════════════════════════════
# FLK0S-Ecosystem · .gitignore (repositorio público — máxima cautela)
# ═══════════════════════════════════════════════════════════════════════════

# Secretos (defensa en profundidad — este repo NO debería tener jamás .env)
.env
.env.*
*.env
.envrc
*.pem
*.key
*.crt
*.cer
*.p12
*.pfx
*.keystore
*.jks
id_rsa*
id_ed25519*
*_rsa
*.gpg
*.asc
secrets/
*.secret

# Volúmenes / data dirs (por si el quickstart deja huellas)
caddy_data/
caddy_config/
**/pki/
**/data/

# OS / editores
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~

# Logs / temporales
*.log
logs/
*.tmp
tmp/
.cache/

# Outputs que NO se versionan (las screenshots originales sí, sus thumbs no)
screenshots/_thumbs/
diagrams/_export/

# Si alguien clona dependencias por error
node_modules/
__pycache__/
*.pyc
.venv/
venv/
